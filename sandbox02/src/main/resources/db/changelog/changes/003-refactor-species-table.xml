<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="003-1" author="you">
        <createTable tableName="scientific_species">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="scientific_name" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="common_name" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="003-2" author="you">
        <sql>
            INSERT INTO scientific_species (scientific_name, common_name)
            SELECT name, classification FROM species;
        </sql>
        <rollback>
            DELETE FROM scientific_species;
        </rollback>
    </changeSet>

    <changeSet id="003-3" author="you">
        <dropTable tableName="species"/>
        <rollback>
            <createTable tableName="species">
                <column name="id" type="bigint" autoIncrement="true">
                    <constraints primaryKey="true" nullable="false"/>
                </column>
                <column name="name" type="varchar(100)">
                    <constraints nullable="false" unique="true"/>
                </column>
                <column name="classification" type="varchar(200)">
                    <constraints nullable="false"/>
                </column>
            </createTable>
            <sql>
                INSERT INTO species (name, classification)
                SELECT scientific_name, common_name FROM scientific_species;
            </sql>
        </rollback>
    </changeSet>
</databaseChangeLog>
